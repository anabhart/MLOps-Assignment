from __future__ import annotations

import argparse
import json
from pathlib import Path

import joblib
import matplotlib
import matplotlib.pyplot as plt
import numpy as np
from sklearn.metrics import (
    accuracy_score,
    confusion_matrix,
    f1_score,
    precision_score,
    recall_score,
    roc_auc_score,
)
from sklearn.model_selection import train_test_split

from heart_disease_mlops.config import TrainingConfig
from heart_disease_mlops.data import load_dataset

matplotlib.use("Agg")


def plot_confusion_matrix(
    y_true: np.ndarray,
    y_pred: np.ndarray,
    output_path: str,
) -> None:
    """Generate and save confusion matrix plot."""
    cm = confusion_matrix(y_true, y_pred)
    fig, ax = plt.subplots(figsize=(8, 6))
    im = ax.imshow(cm, interpolation="nearest", cmap=plt.cm.Blues)
    ax.figure.colorbar(im, ax=ax)

    ax.set(
        xticks=np.arange(cm.shape[1]),
        yticks=np.arange(cm.shape[0]),
        xticklabels=["No Disease", "Disease"],
        yticklabels=["No Disease", "Disease"],
        ylabel="True label",
        xlabel="Predicted label",
    )

    thresh = cm.max() / 2.0
    for i in range(cm.shape[0]):
        for j in range(cm.shape[1]):
            ax.text(
                j,
                i,
                format(cm[i, j], "d"),
                ha="center",
                va="center",
                color="white" if cm[i, j] > thresh else "black",
            )

    fig.tight_layout()
    plt.savefig(output_path, dpi=150, bbox_inches="tight")
    plt.close()


def evaluate_model(
    input_path: str | None,
    model_path: str,
    metrics_out: str,
    confusion_matrix_out: str | None = None,
) -> dict[str, float]:
    config = TrainingConfig()
    df = load_dataset(input_path)  # None → fetch from UCI with auto-cache

    X = df.drop(columns=[config.target_column])
    y = df[config.target_column]

    _, X_test, _, y_test = train_test_split(
        X,
        y,
        test_size=config.test_size,
        random_state=config.random_state,
        stratify=y,
    )

    model = joblib.load(model_path)
    y_pred = model.predict(X_test)
    y_prob = model.predict_proba(X_test)[:, 1]

    metrics = {
        "accuracy": float(accuracy_score(y_test, y_pred)),
        "precision": float(precision_score(y_test, y_pred, zero_division=0)),
        "recall": float(recall_score(y_test, y_pred, zero_division=0)),
        "f1": float(f1_score(y_test, y_pred, zero_division=0)),
        "roc_auc": float(roc_auc_score(y_test, y_prob)),
    }

    output_path = Path(metrics_out)
    output_path.parent.mkdir(parents=True, exist_ok=True)
    output_path.write_text(json.dumps(metrics, indent=2), encoding="utf-8")

    if confusion_matrix_out:
        cm_path = Path(confusion_matrix_out)
        cm_path.parent.mkdir(parents=True, exist_ok=True)
        plot_confusion_matrix(y_test.values, y_pred, str(cm_path))

    return metrics


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Evaluate heart disease classifier")
    parser.add_argument(
        "--input",
        default=None,
        help="Path to raw CSV data. Omit to fetch automatically from UCI.",
    )
    parser.add_argument("--model-path", required=True, help="Path to saved model")
    parser.add_argument("--metrics-out", required=True, help="Path to save evaluation metrics")
    parser.add_argument(
        "--confusion-matrix-out",
        default=None,
        help="Path to save confusion matrix plot",
    )
    return parser.parse_args()


if __name__ == "__main__":
    args = parse_args()
    output_metrics = evaluate_model(
        input_path=args.input,
        model_path=args.model_path,
        metrics_out=args.metrics_out,
        confusion_matrix_out=args.confusion_matrix_out,
    )
    print(json.dumps(output_metrics, indent=2))


