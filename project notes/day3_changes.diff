from __future__ import annotations

import json
from pathlib import Path

from heart_disease_mlops.train import train_model


def compare_models(
    input_path: str | None = None,
    output_dir: str = "models/baseline_comparison",
) -> None:
    """Train and compare baseline models."""
    output_path = Path(output_dir)
    output_path.mkdir(parents=True, exist_ok=True)

    models = ["logistic", "random_forest"]
    results = []

    for model_name in models:
        print(f"\nTraining {model_name}...")
        model_out = str(output_path / f"{model_name}_model.joblib")
        metrics_out = str(output_path / f"{model_name}_metrics.json")

        metrics = train_model(
            input_path=input_path,
            model_out=model_out,
            metrics_out=metrics_out,
            model_name=model_name,
        )
        results.append(metrics)
        print(json.dumps(metrics, indent=2))

    comparison_path = output_path / "comparison.json"
    comparison_path.write_text(json.dumps(results, indent=2), encoding="utf-8")

    print(f"\n{'Model':<20} {'Accuracy':<10} {'Precision':<10} {'Recall':<10} {'F1':<10} {'ROC-AUC':<10}")
    print("-" * 70)
    for result in results:
        print(
            f"{result['model_name']:<20} "
            f"{result['accuracy']:<10.4f} "
            f"{result['precision']:<10.4f} "
            f"{result['recall']:<10.4f} "
            f"{result['f1']:<10.4f} "
            f"{result['roc_auc']:<10.4f}"
        )

    best_model = max(results, key=lambda x: x["f1"])
    print(f"\nBest model by F1 score: {best_model['model_name']} (F1: {best_model['f1']:.4f})")


if __name__ == "__main__":
    compare_models()


